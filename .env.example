# ============================================
# AI 短剧生成�?· 生产环境配置
# 复制�?.env 并填入真实�?# ============================================

# --- 数据�?---
POSTGRES_PASSWORD=your_strong_password_here
# docker-compose 内部通信，无需修改
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@db:5432/onestoryboard?schema=public

# --- Redis ---
REDIS_PASSWORD=your_redis_password_here
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# --- 应用 ---
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-domain.com

# --- 存储（三选一�?--
# 选项 A：S3 兼容（阿里云 OSS / 腾讯 COS / MinIO）推荐生产使�?S3_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
S3_REGION=cn-beijing
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key

# 选项 B：本地磁盘（通过 docker volume 持久化，仅单机部署可用）
# 注意：Seedance 调用时需要公网可访问�?URL，本地存储需配合 nginx 反代域名
LOCAL_ASSETS_DIR=.local-assets

# ============================================
# AI 模型（三个固定模型）
# ============================================

# --- 文本模型：豆�?Doubao Seed 2.0 ---
VOLCENGINE_ARK_API_KEY=your_ark_api_key
VOLCENGINE_ACCESS_KEY_ID=your_access_key_id
VOLCENGINE_SECRET_ACCESS_KEY=your_secret_access_key
DOUBAO_ENDPOINT_ID=doubao-seed-2-0-lite-260428

# --- 生图模型：腾�?OG Image 2 ---
TENCENT_SECRET_ID=your_tencent_secret_id
TENCENT_SECRET_KEY=your_tencent_secret_key
TENCENT_VOD_SUB_APP_ID=your_sub_app_id
# 腾讯 OG 生图轮询配置（默认值已适配生产，通常无需修改�?TENCENT_AIGC_IMAGE_POLL_MAX_ATTEMPTS=200
TENCENT_AIGC_IMAGE_POLL_INTERVAL_MS=3000

# --- 备用生图：阿里云万相 2.7（OG 失败时自动切换）---
ALIBABA_DASHSCOPE_API_KEY=your_dashscope_api_key

# ============================================
# 默认模型（勿改）
# ============================================
DEFAULT_TEXT_MODEL=doubao-seed-2-0
DEFAULT_IMAGE_MODEL=tencent-og-medium
DEFAULT_VIDEO_MODEL=seedance-2.0

# ============================================
# Worker 并发（根据服务器配置调整�?# ============================================
WORKER_SHOT_CONCURRENCY=3
PIPELINE_IMAGE_CONCURRENCY=3
